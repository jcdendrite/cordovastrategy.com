---
import Layout from '../layouts/Layout.astro'
import BookingCta from '../components/BookingCta.astro'
import { Image } from 'astro:assets'
const headshotUrl = 'https://assets.cordovastrategy.com/headshot.jpg'

const proofPoints = [
	{ metric: '$2.3M+', description: 'Annual cost savings through platform modernization' },
	{ metric: '90%', description: 'Partner retention through data platform migration' },
	{ metric: '50%', description: 'Faster incident resolution through modernized tooling' },
	{ metric: 'Millions', description: 'Users supported through infrastructure scaling' },
	{ metric: '2', description: 'Products built and launched from zero to market' },
]
---

<Layout
	title="Cordova Strategy — Jared Cordova"
	description="Fractional CTO and technology consulting for high-growth companies. 15 years of engineering leadership experience."
>
	<!-- Header -->
	<header class="px-6 py-6 max-w-5xl mx-auto">
		<p class="text-lg font-semibold tracking-tight text-stone-900">Cordova Strategy <span class="text-stone-400">—</span> Jared Cordova</p>
	</header>

	<!-- Hero -->
	<section class="flex items-center justify-center min-h-[85vh] px-6">
		<h1 class="max-w-3xl text-4xl sm:text-5xl md:text-6xl font-bold leading-tight tracking-tight text-stone-900 text-center">
			Technical problems keeping you up at night? I put them to rest.
		</h1>
	</section>

	<!-- Does This Sound Like You? -->
	<section class="px-6 py-24 max-w-3xl mx-auto">
		<h2 class="text-3xl font-bold tracking-tight text-stone-900 mb-12">Does This Sound Like You?</h2>
		<ul class="space-y-6 text-lg text-stone-700">
			<li class="flex gap-3">
				<span class="text-stone-400 shrink-0">&bull;</span>
				<span>You vibe-coded an app, but you're not an engineer and aren't sure how to support it with live users.</span>
			</li>
			<li class="flex gap-3">
				<span class="text-stone-400 shrink-0">&bull;</span>
				<span>Your senior technical staff doesn't have enough time to spend in areas they are most needed.</span>
			</li>
			<li class="flex gap-3">
				<span class="text-stone-400 shrink-0">&bull;</span>
				<span>Your development has persistent slow-downs or quality issues that are hard to diagnose.</span>
			</li>
			<li class="flex gap-3">
				<span class="text-stone-400 shrink-0">&bull;</span>
				<span>You're worried about insufficient technical oversight — unsupervised AI processes, junior engineers, or inherited tech debt.</span>
			</li>
			<li class="flex gap-3">
				<span class="text-stone-400 shrink-0">&bull;</span>
				<span>Your upcoming launch secures critical revenue, and you need to de-risk it from the engineering side.</span>
			</li>
		</ul>
		<div class="mt-12">
			<BookingCta />
		</div>
	</section>

	<!-- What I Bring -->
	<section class="px-6 py-24 max-w-5xl mx-auto">
		<h2 class="text-3xl font-bold tracking-tight text-stone-900 mb-12">What I Bring</h2>
		<div class="flex flex-col md:flex-row gap-10 items-start">
			<Image
				src={headshotUrl}
				alt="Jared Cordova"
				width={192}
				height={192}
				class="w-48 h-48 rounded-xl object-cover shrink-0"
			/>
			<p class="text-lg leading-relaxed text-stone-700">
				I've spent 15 years as a builder and leader in high-growth companies — from founding engineer at a bootstrapped startup to senior director leading 35+ engineers. I've launched products from scratch, turned around struggling platforms, and developed engineers into leaders. What sets me apart is that I untangle the full picture: the systems, the people, and the processes — to get at what your business actually needs to thrive.
			</p>
		</div>
		<div class="mt-16 grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-5 gap-6">
			{proofPoints.map((point) => (
				<div class="bg-stone-100 rounded-lg p-5 text-center">
					<p class="text-2xl font-bold text-stone-900">{point.metric}</p>
					<p class="text-sm text-stone-600 mt-1">{point.description}</p>
				</div>
			))}
		</div>
		<p class="mt-10 text-center text-xs text-stone-400">
			Co-inventor, AI health coaching platform patent · Stanford BS in Symbolic Systems
		</p>
	</section>

	<!-- Footer -->
	<footer class="px-6 py-24 max-w-3xl mx-auto text-center">
		<p class="text-3xl font-bold tracking-tight text-stone-900 mb-8">
			Let's talk about what's keeping you up at night.
		</p>
		<BookingCta />
		<div class="mt-12 flex items-center justify-center gap-4">
			<a href="https://linkedin.com/in/jakcordova" target="_blank" rel="noopener" aria-label="LinkedIn" class="text-stone-400 hover:text-stone-600 transition-colors">
				<svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
					<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
				</svg>
			</a>
		</div>
		<div class="mt-8 text-sm text-stone-400">
			<p>&copy; 2026 Cordova Strategy</p>
			<p class="mt-1">Remote | Sacramento &amp; SF Bay Area</p>
		</div>
	</footer>
</Layout>

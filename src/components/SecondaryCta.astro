---
interface Props { label: string; href: string }
const { label, href } = Astro.props
---
<a href={href} class="inline-flex items-center gap-1.5 font-medium text-[15px] text-accent hover:text-accent-d no-underline transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent">
  {label}<span aria-hidden="true">→</span>
</a>

<div class="hero-art w-full">
  <svg viewBox="0 0 326 316" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:auto;display:block;" role="img" aria-label="A tangled web of people and AI tools with dead-end and pruned connections">
    <defs><style>
      .bx{fill:#14342A;stroke:#bcd4c5;stroke-width:1.4;}
      .bl{font-family:"IBM Plex Mono",monospace;font-size:10px;fill:#cfe0d7;}
      .web{stroke:#c9d6ce;stroke-width:1.6;fill:none;opacity:.6;}
      .dead{stroke:#9ec3ad;stroke-width:1.6;fill:none;opacity:.5;stroke-dasharray:1 5;}
      .deadend{fill:none;stroke:#9ec3ad;stroke-width:1.4;opacity:.55;}
      .prune{stroke:#d8a657;stroke-width:2;fill:none;opacity:.9;}
      .xm{stroke:#d8a657;stroke-width:2;}
      .clean{stroke:#7fb295;stroke-width:1.8;fill:none;}
      .node{fill:#14342A;stroke:#bcd4c5;stroke-width:1.4;}
    </style></defs>
    <!-- LEFT: messy web of people (circles) and tools (boxes) -->
    <g class="web">
      <path d="M55,55 L141,212"/><path d="M183,52 L48,184"/><path d="M115,118 L175,258"/>
      <path d="M55,55 L192,160"/><path d="M183,52 L115,118"/><path d="M192,160 L68,260"/>
      <path d="M141,212 L48,184"/>
    </g>
    <g class="dead">
      <path d="M192,160 L312,150"/><path d="M48,184 L4,150"/>
      <path d="M175,258 L312,302"/><path d="M115,118 L120,34"/>
    </g>
    <g class="deadend">
      <circle cx="312" cy="150" r="2.6"/><circle cx="4" cy="150" r="2.6"/>
      <circle cx="312" cy="302" r="2.6"/><circle cx="120" cy="34" r="2.6"/>
    </g>
    <g class="prune">
      <path d="M55,55 L183,52"/><path d="M68,260 L175,258"/>
      <path d="M115,118 L48,184"/><path d="M192,160 L141,212"/>
    </g>
    <g class="xm">
      <line x1="114" y1="47" x2="124" y2="59"/><line x1="124" y1="47" x2="114" y2="59"/>
      <line x1="116" y1="253" x2="126" y2="265"/><line x1="126" y1="253" x2="116" y2="265"/>
      <line x1="76" y1="145" x2="86" y2="157"/><line x1="86" y1="145" x2="76" y2="157"/>
      <line x1="161" y1="180" x2="171" y2="192"/><line x1="171" y1="180" x2="161" y2="192"/>
    </g>
    <g>
      <rect class="bx" x="150" y="40" width="66" height="24" rx="5"/><text class="bl" x="183" y="56" text-anchor="middle">AI tool</text>
      <rect class="bx" x="15" y="172" width="66" height="24" rx="5"/><text class="bl" x="48" y="188" text-anchor="middle">AI tool</text>
      <rect class="bx" x="35" y="248" width="66" height="24" rx="5"/><text class="bl" x="68" y="264" text-anchor="middle">AI tool</text>
      <rect class="bx" x="108" y="200" width="66" height="24" rx="5"/><text class="bl" x="141" y="216" text-anchor="middle">AI tool</text>
    </g>
    <g>
      <g transform="translate(55,55)"><circle r="13" class="node"/><circle cy="-3.5" r="2.6" fill="#cfe0d7"/><path d="M-6,7 Q0,0 6,7" fill="none" stroke="#cfe0d7" stroke-width="1.4"/></g>
      <g transform="translate(115,118)"><circle r="13" class="node"/><circle cy="-3.5" r="2.6" fill="#cfe0d7"/><path d="M-6,7 Q0,0 6,7" fill="none" stroke="#cfe0d7" stroke-width="1.4"/></g>
      <g transform="translate(192,160)"><circle r="13" class="node"/><circle cy="-3.5" r="2.6" fill="#cfe0d7"/><path d="M-6,7 Q0,0 6,7" fill="none" stroke="#cfe0d7" stroke-width="1.4"/></g>
      <g transform="translate(175,258)"><circle r="13" class="node"/><circle cy="-3.5" r="2.6" fill="#cfe0d7"/><path d="M-6,7 Q0,0 6,7" fill="none" stroke="#cfe0d7" stroke-width="1.4"/></g>
    </g>
  </svg>
</div>
